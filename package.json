{
  "name": "obsidian-adora-cortex",
  "version": "0.1.0",
  "description": "Adora Cortex Obsidian plugin for syncing company context into a shared knowledge base",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "build:cli": "node cli/esbuild.cli.mjs",
    "sync": "node cortex-sync.js",
    "deploy": "npm run build && PLUGIN_DIR=\"${OBSIDIAN_PLUGIN_DIR:-$HOME/Desktop/Adora AI/.obsidian/plugins/adora-cortex}\" && cp main.js manifest.json styles.css \"$PLUGIN_DIR\"",
    "perplexity:import": "node scripts/perplexity-import.mjs",
    "perplexity:pull": "node scripts/perplexity-daily-export.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "cortex",
    "meeting-notes",
    "knowledge-graph"
  ],
  "author": "Adora AI",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.0",
    "obsidian": "latest",
    "playwright": "^1.54.1",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
